# Secrets de la stack Docker complète (web + api + db).
# Copier en `.env` (gitignoré, chmod 600 sur le serveur) et renseigner des
# valeurs FORTES. Ne JAMAIS committer de valeurs réelles (repo public).

# --- PostgreSQL ---
POSTGRES_DB=watchlist
POSTGRES_USER=watchlist
# Mot de passe fort et unique (la DB n'est jamais exposée hors du réseau compose) :
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Auth API (JWT) ---
# Générer un secret fort : openssl rand -hex 32
JWT_SECRET=change-me-with-openssl-rand-hex-32
# Cookie de session envoyé uniquement en HTTPS. true en prod (derrière NPM + Let's Encrypt).
COOKIE_SECURE=true
