# Copier en `backend/.env` (gitignoré) pour le dev local, ou injecter via le
# docker-compose en production. Ne JAMAIS committer de valeurs réelles (repo public).

# DSN SQLAlchemy async (driver asyncpg).
# Dev local (Postgres dockerisé) :
DATABASE_URL=postgresql+asyncpg://watchlist:watchlist@localhost:5432/watchlist
# En conteneur (api → service `db` du compose), l'hôte devient `db` :
# DATABASE_URL=postgresql+asyncpg://watchlist:CHANGEME@db:5432/watchlist

# --- Authentification (JWT) ---
# ⚠️ OBLIGATOIRE en prod : un secret fort et unique (ex. `openssl rand -hex 32`).
JWT_SECRET=dev-insecure-secret-change-me-in-prod
# Mettre à true en prod (cookie envoyé uniquement en HTTPS) :
COOKIE_SECURE=false
